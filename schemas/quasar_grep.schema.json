{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "quasar-grep JSON summary",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "files": {
      "type": "integer",
      "minimum": 0
    },
    "matches": {
      "type": "integer",
      "minimum": 0
    },
    "elapsed_ms": {
      "type": "number",
      "minimum": 0
    }
  },
  "required": [
    "matches"
  ]
}