{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "quasar-grep JSON output",
  "type": "object",
  "properties": {
    "file": {
      "type": "string"
    },
    "matches": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "line": {
            "type": "integer",
            "minimum": 0
          },
          "column": {
            "type": "integer",
            "minimum": 0
          },
          "excerpt": {
            "type": "string"
          }
        },
        "required": [
          "line",
          "column"
        ]
      }
    }
  },
  "required": [
    "file",
    "matches"
  ]
}